# ===== FEDPOLY NASARAWA ID SYSTEM — ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Flask secret key (change this to a long random string in production)
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Encryption key for QR tokens (change this in production)
ENCRYPTION_KEY=change-this-encryption-key-in-production-fedpoly

# Database URL
# For local development: leave blank (uses SQLite automatically)
# For production (Render.com PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Base URL (IMPORTANT: set this to your deployed domain)
# For local development: http://localhost:5000
# For production: https://your-app.onrender.com
BASE_URL=http://localhost:5000

# Flask environment
FLASK_ENV=development
# For production: FLASK_ENV=production
